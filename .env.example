# Pinata IPFS — required for lesson content uploads
# Get your JWT at https://app.pinata.cloud/keys
PINATA_JWT=your_pinata_jwt_here

# ReOwn (WalletConnect) AppKit project ID — required for wallet connection
# Get yours at https://cloud.reown.com
NEXT_PUBLIC_REOWN_PROJECT_ID=your_reown_project_id_here
